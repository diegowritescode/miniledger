{
  "check-coverage": true,
  "all": false,
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.spec.ts",
    "**/*.module.ts",
    "**/*.dto.ts",
    "**/*.schema.ts",
    "src/main.ts",
    "src/migrate.ts",
    "src/load-env-file.ts",
    "src/**/*.d.ts"
  ],
  "reporter": ["text-summary", "text"],
  "lines": 90,
  "statements": 90,
  "functions": 85,
  "branches": 75
}
