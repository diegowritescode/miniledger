# Copy to .env and fill in. Never commit the real .env.

# App
NODE_ENV=development
PORT=3000

# PostgreSQL (host port 5433 — see docker-compose.yml)
# In production DATABASE_URL is the least-privilege `miniledger_app` role (ADR-011).
DATABASE_URL=postgres://miniledger:miniledger@localhost:5433/miniledger
POSTGRES_USER=miniledger
POSTGRES_PASSWORD=miniledger
POSTGRES_DB=miniledger
# Optional: owner/admin role used to run DDL migrations (ADR-011). Falls back to
# DATABASE_URL when unset (single-role local/CI). Set it in production.
# MIGRATION_DATABASE_URL=postgres://owner:password@host:5432/miniledger

# AccessCore (authN via JWKS + PEP via the SDK). Point these at your AccessCore instance.
ACCESSCORE_BASE_URL=http://localhost:3001
ACCESSCORE_JWKS_URL=http://localhost:3001/.well-known/jwks.json
ACCESSCORE_JWT_ISSUER=https://auth.accesscore.dev
ACCESSCORE_JWT_AUDIENCE=accesscore
ACCESSCORE_CLOCK_SKEW_SECONDS=30
ACCESSCORE_CHECK_TIMEOUT_MS=3000

# Observability & abuse controls
LOG_LEVEL=info
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
